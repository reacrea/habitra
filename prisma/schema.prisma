generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BROKER_OWNER
  AGENT
  BUYER
  SELLER
}

enum MembershipRole {
  OWNER
  MANAGER
  AGENT
  MEMBER
}

enum LeadStatus {
  NUEVO
  CONTACTADO
  CALIFICADO
  DESCARTADO
  CONVERTIDO
}

enum LeadTemperature {
  FRIO
  TIBIO
  CALIENTE
}

enum LeadType {
  COMPRADOR
  VENDEDOR
  INVERSIONISTA
  ARRENDATARIO
}

enum PropertyType {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
  LOCAL_COMERCIAL
  BODEGA
  PENTHOUSE
  OTRO
}

enum OperationType {
  VENTA
  RENTA
}

enum PropertyStatus {
  BORRADOR
  PUBLICADA
  EN_NEGOCIACION
  APARTADA
  VENDIDA
  INACTIVA
}

enum DocumentStatus {
  PENDIENTE
  CARGADO
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum DocumentType {
  ESCRITURA
  IDENTIFICACION
  COMPROBANTE_DOMICILIO
  PREDIAL
  AGUA
  LIBERTAD_GRAVAMEN
  AVALUO
  CARTA_OFERTA
  CONTRATO_PROMESA
  CARTA_APROBACION_CREDITO
  ESTADO_CUENTA
  OTROS
}

enum TransactionStage {
  LEAD_CREADO
  COMPRADOR_CALIFICADO
  PROPIEDAD_SELECCIONADA
  VISITA_REALIZADA
  OFERTA_ENVIADA
  OFERTA_ACEPTADA
  APARTADO_PROMESA
  CREDITO_EN_PROCESO
  AVALUO_SOLICITADO
  AVALUO_COMPLETADO
  EXPEDIENTE_NOTARIAL
  FIRMA_PROGRAMADA
  ESCRITURA_FIRMADA
  REGISTRO_EN_PROCESO
  ENTREGA_COMPLETADA
  CERRADA
}

enum TransactionStatus {
  ACTIVA
  PAUSADA
  EN_RIESGO
  CANCELADA
  CERRADA
}

enum TimelineStepStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADO
  BLOQUEADO
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  BLOQUEADA
}

enum CreditType {
  INFONAVIT
  FOVISSSTE
  BANCARIO
  COFINAVIT
  CONTADO
  MIXTO
  OTRO
}

enum PlanType {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum PaymentType {
  CONTADO
  CREDITO
  MIXTO
}

enum Currency {
  MXN
  USD
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  emailVerified      Boolean       @default(false)
  name               String
  image              String?
  phone              String?
  role               UserRole      @default(AGENT)
  isActive           Boolean       @default(true)
  lastLoginAt        DateTime?
  sessions           Session[]
  accounts           Account[]
  memberships        Membership[]
  assignedLeads      Lead[]        @relation("LeadAssignedAgent")
  assignedBuyers     Buyer[]       @relation("BuyerAssignedAgent")
  assignedSellers    Seller[]      @relation("SellerAssignedAgent")
  assignedProperties Property[]    @relation("PropertyAssignedAgent")
  agentTransactions  Transaction[] @relation("TransactionAgent")
  assignedTasks      Task[]        @relation("TaskAssignee")
  authoredNotes      Note[]        @relation("NoteAuthor")
  sentMessages       Message[]     @relation("MessageSender")
  receivedMessages   Message[]     @relation("MessageReceiver")
  uploadedDocuments  Document[]    @relation("DocumentUploader")
  activityLogs       ActivityLog[] @relation("ActivityActor")
  buyerProfile       Buyer?        @relation("BuyerUserProfile")
  sellerProfile      Seller?       @relation("SellerUserProfile")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("user")
}

/// Sesiones Better Auth
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Cuentas OAuth / credencial (contrasena email)
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Organization {
  id                   String                @id @default(cuid())
  slug                 String                @unique
  name                 String
  city                 String?
  state                String?
  country              String                @default("Mexico")
  memberships          Membership[]
  leads                Lead[]
  buyers               Buyer[]
  sellers              Seller[]
  properties           Property[]
  transactions         Transaction[]
  documents            Document[]
  tasks                Task[]
  notes                Note[]
  messages             Message[]
  financialSimulations FinancialSimulation[]
  subscriptions        Subscription[]
  activityLogs         ActivityLog[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Lead {
  id              String          @id @default(cuid())
  organizationId  String
  name            String
  email           String?
  phone           String?
  type            LeadType
  source          String
  status          LeadStatus      @default(NUEVO)
  temperature     LeadTemperature @default(TIBIO)
  assignedAgentId String?
  notesText       String?
  lastContactAt   DateTime?
  convertedBuyer  Buyer?
  convertedSeller Seller?
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent   User?           @relation("LeadAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  tasks           Task[]
  notes           Note[]
  activities      ActivityLog[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId, status])
  @@index([assignedAgentId])
}

model Buyer {
  id                  String                @id @default(cuid())
  organizationId      String
  userId              String?               @unique
  sourceLeadId        String?               @unique
  name                String
  email               String?
  phone               String?
  maxBudget           Decimal?              @db.Decimal(14, 2)
  downPayment         Decimal?              @db.Decimal(14, 2)
  monthlyIncome       Decimal?              @db.Decimal(14, 2)
  creditType          CreditType            @default(BANCARIO)
  desiredZone         String?
  desiredPropertyType PropertyType?
  bedrooms            Int?
  bathrooms           Int?
  urgency             Int?                  @default(3)
  buyingScore         Int?                  @default(50)
  assignedAgentId     String?
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?                 @relation("BuyerUserProfile", fields: [userId], references: [id], onDelete: SetNull)
  sourceLead          Lead?                 @relation(fields: [sourceLeadId], references: [id], onDelete: SetNull)
  assignedAgent       User?                 @relation("BuyerAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  transactions        Transaction[]         @relation("TransactionBuyer")
  documents           Document[]
  simulations         FinancialSimulation[]
  tasks               Task[]
  notes               Note[]
  activities          ActivityLog[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([organizationId, buyingScore])
  @@index([assignedAgentId])
}

model Seller {
  id              String        @id @default(cuid())
  organizationId  String
  userId          String?       @unique
  sourceLeadId    String?       @unique
  name            String
  email           String?
  phone           String?
  urgency         Int?          @default(3)
  expectedPrice   Decimal?      @db.Decimal(14, 2)
  sellingReason   String?
  assignedAgentId String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?         @relation("SellerUserProfile", fields: [userId], references: [id], onDelete: SetNull)
  sourceLead      Lead?         @relation(fields: [sourceLeadId], references: [id], onDelete: SetNull)
  assignedAgent   User?         @relation("SellerAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  properties      Property[]
  transactions    Transaction[] @relation("TransactionSeller")
  documents       Document[]
  tasks           Task[]
  notes           Note[]
  activities      ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([assignedAgentId])
}

model Property {
  id                    String            @id @default(cuid())
  organizationId        String
  slug                  String            @unique
  title                 String
  description           String
  fullDescription       String?
  propertyType          PropertyType
  operationType         OperationType
  price                 Decimal           @db.Decimal(14, 2)
  currency              Currency          @default(MXN)
  address               String
  city                  String
  state                 String
  neighborhood          String?
  postalCode            String?
  latitude              Decimal?          @db.Decimal(10, 7)
  longitude             Decimal?          @db.Decimal(10, 7)
  bedrooms              Int?
  bathrooms             Int?
  parkingSpaces         Int?
  landArea              Decimal?          @db.Decimal(12, 2)
  constructionArea      Decimal?          @db.Decimal(12, 2)
  age                   Int?
  status                PropertyStatus    @default(BORRADOR)
  sellerId              String?
  assignedAgentId       String?
  readinessScore        Int               @default(0)
  suggestedPriceMin     Decimal?          @db.Decimal(14, 2)
  suggestedPriceMax     Decimal?          @db.Decimal(14, 2)
  suggestedPriceTarget  Decimal?          @db.Decimal(14, 2)
  risks                 String[]
  isFeatured            Boolean           @default(false)
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seller                Seller?           @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  assignedAgent         User?             @relation("PropertyAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  images                PropertyImage[]
  amenities             PropertyAmenity[]
  documents             Document[]
  transactions          Transaction[]     @relation("TransactionProperty")
  simulations           FinancialSimulation[]
  tasks                 Task[]
  notes                 Note[]
  activities            ActivityLog[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([sellerId])
  @@index([assignedAgentId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([propertyId, order])
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, name])
}

model Document {
  id               String         @id @default(cuid())
  organizationId   String
  type             DocumentType
  status           DocumentStatus @default(PENDIENTE)
  title            String
  description      String?
  fileName         String?
  fileUrl          String
  mimeType         String?
  sizeBytes        Int?
  reviewComments   String?
  buyerId          String?
  sellerId         String?
  propertyId       String?
  transactionId    String?
  uploadedByUserId String?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  buyer            Buyer?         @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  seller           Seller?        @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  property         Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction      Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  uploadedBy       User?          @relation("DocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  timelineSteps    TransactionTimelineStep[]
  activities       ActivityLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([buyerId])
  @@index([sellerId])
  @@index([propertyId])
  @@index([transactionId])
}

model Transaction {
  id                   String                    @id @default(cuid())
  organizationId       String
  propertyId           String
  buyerId              String
  sellerId             String
  agentId              String
  offeredPrice         Decimal?                  @db.Decimal(14, 2)
  acceptedPrice        Decimal?                  @db.Decimal(14, 2)
  status               TransactionStatus         @default(ACTIVA)
  currentStage         TransactionStage          @default(LEAD_CREADO)
  estimatedClosingDate DateTime?
  paymentType          PaymentType               @default(CREDITO)
  creditType           CreditType?
  notaryName           String?
  appraiserName        String?
  bankName             String?
  probabilityToClose   Int                       @default(50)
  notesText            String?
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property             Property                  @relation("TransactionProperty", fields: [propertyId], references: [id], onDelete: Cascade)
  buyer                Buyer                     @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller               Seller                    @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  agent                User                      @relation("TransactionAgent", fields: [agentId], references: [id], onDelete: Cascade)
  timelineSteps        TransactionTimelineStep[]
  documents            Document[]
  tasks                Task[]
  notes                Note[]
  messages             Message[]
  simulations          FinancialSimulation[]
  activities           ActivityLog[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([organizationId, status])
  @@index([agentId])
}

model TransactionTimelineStep {
  id            String             @id @default(cuid())
  transactionId String
  name          String
  description   String?
  responsibleRole UserRole
  estimatedDate DateTime?
  completedDate DateTime?
  status        TimelineStepStatus @default(PENDIENTE)
  notes         String?
  relatedDocumentId String?
  order         Int                @default(0)
  transaction   Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  relatedDocument Document?        @relation(fields: [relatedDocumentId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([transactionId, order])
}

model Task {
  id             String      @id @default(cuid())
  organizationId String
  title          String
  description    String?
  status         TaskStatus  @default(PENDIENTE)
  dueDate        DateTime?
  assigneeId     String?
  leadId         String?
  buyerId        String?
  sellerId       String?
  propertyId     String?
  transactionId  String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  buyer          Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  seller         Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  content        String
  authorId       String?
  leadId         String?
  buyerId        String?
  sellerId       String?
  propertyId     String?
  transactionId  String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User?        @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  buyer          Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  seller         Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Message {
  id             String       @id @default(cuid())
  organizationId String
  senderId       String
  receiverId     String
  transactionId  String?
  content        String
  isRead         Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([transactionId])
}

model FinancialSimulation {
  id                    String      @id @default(cuid())
  organizationId        String
  buyerId               String?
  propertyId            String?
  transactionId         String?
  propertyPrice         Decimal     @db.Decimal(14, 2)
  downPayment           Decimal     @db.Decimal(14, 2)
  years                 Int
  annualRate            Decimal     @db.Decimal(5, 2)
  creditType            CreditType
  notaryCostPct         Decimal     @db.Decimal(5, 2)
  appraisalCost         Decimal     @db.Decimal(14, 2)
  otherCosts            Decimal     @db.Decimal(14, 2)
  estimatedMonthly      Decimal     @db.Decimal(14, 2)
  estimatedClosingCosts Decimal     @db.Decimal(14, 2)
  initialTotalNeeded    Decimal     @db.Decimal(14, 2)
  affordabilityRatio    Decimal     @db.Decimal(6, 3)
  recommendation        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  buyer                 Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  property              Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction           Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt             DateTime     @default(now())

  @@index([organizationId])
}

model Plan {
  id                String        @id @default(cuid())
  type              PlanType      @unique
  name              String
  priceMxn          Decimal       @db.Decimal(14, 2)
  billingCadence    String
  minUsers          Int
  maxUsers          Int?
  description       String?
  successFeePercent Decimal       @db.Decimal(5, 2)
  isActive          Boolean       @default(true)
  subscriptions     Subscription[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String
  planId         String
  status         String       @default("ACTIVE")
  startDate      DateTime
  endDate        DateTime?
  seats          Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  description    String?
  metadata       Json?
  leadId         String?
  buyerId        String?
  sellerId       String?
  propertyId     String?
  transactionId  String?
  documentId     String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  buyer          Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  seller         Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  document       Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
